<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    tools:context=".Scanner_Api">


    <Button
        android:id="@+id/buttonBarcode"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:layout_marginTop="50dp"
        android:onClick="onBarcodeScannerStart"
        android:text="@string/barcodeScanAct"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/buttonRFID"
        android:layout_width="300dp"
        android:layout_height="70dp"
        android:layout_marginTop="35dp"
        android:onClick="onRFIDScannerStart"
        android:text="@string/rfidScanAct"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonBarcode" />
</androidx.constraintlayout.widget.ConstraintLayout>